# Huntress Configuration
# Copy this file to .env and fill in your credentials

# ============================================================================
# HackerOne API Configuration (Required for Report Submission)
# ============================================================================
# Get your API credentials from: https://hackerone.com/settings/api_token/edit
HACKERONE_API_USERNAME=your_hackerone_username
HACKERONE_API_TOKEN=your_api_token_here

# ============================================================================
# Anthropic API (Required for AI Agents)
# ============================================================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================================
# Qdrant Vector Database (Required for Duplicate Detection & Memory)
# ============================================================================
# Local Qdrant instance (default)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Or use Qdrant Cloud
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# ============================================================================
# GitHub API (Optional - for PoC duplicate detection)
# ============================================================================
# Get a personal access token from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# ============================================================================
# Burp Collaborator (Optional - for SSRF/XXE testing)
# ============================================================================
COLLABORATOR_URL=https://your-subdomain.burpcollaborator.net

# ============================================================================
# OAuth Testing Configuration (CRITICAL for Production)
# ============================================================================
# Custom callback domain for OAuth redirect_uri testing
# Using burpcollaborator.net or interactsh.com results in "low-impact" ratings
# Set up your own domain with DNS pointing to your server
# Example: oauth-huntress.com, callback.yourdomain.com
OAUTH_CALLBACK_DOMAIN=oauth-huntress.com

# Fallback to Burp Collaborator if custom domain not configured (not recommended)
# Leave empty to require custom domain
OAUTH_FALLBACK_TO_COLLABORATOR=false

# ============================================================================
# Proxy Configuration (Optional)
# ============================================================================
# HTTP/HTTPS proxy for requests
HTTP_PROXY=
HTTPS_PROXY=

# ============================================================================
# Rate Limiting (Optional)
# ============================================================================
# Maximum requests per minute
MAX_REQUESTS_PER_MINUTE=60

# ============================================================================
# Logging (Optional)
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# Development Settings (Optional)
# ============================================================================
# Enable debug mode
DEBUG=false

# Skip SSL verification (not recommended for production)
NODE_TLS_REJECT_UNAUTHORIZED=1

# ============================================================================
# HackTheBox API (Required for Phase 5 Training Loop)
# ============================================================================
# Get your API token from: https://www.hackthebox.com/home/settings
HTB_API_TOKEN=your_htb_api_token_here

# ============================================================================
# OpenAI API (Required for Training Data Embeddings)
# ============================================================================
# Used for generating embeddings for training data storage
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================================
# HuggingFace API (Required for Phase 5.2 LoRA Training)
# ============================================================================
# Required to download Llama-3.1-70B base model for training
# Get your token from: https://huggingface.co/settings/tokens
# You must accept the Llama 3.1 license at: https://huggingface.co/meta-llama/Llama-3.1-70B-Instruct
HUGGINGFACE_TOKEN=hf_your_huggingface_token_here

# ============================================================================
# Phase 5 Training Configuration (Optional)
# ============================================================================
# Training data quality threshold (0.0-1.0)
TRAINING_QUALITY_THRESHOLD=0.6

# Minimum training examples before triggering training
MIN_TRAINING_EXAMPLES=10

# Maximum days between training runs
MAX_DAYS_BETWEEN_TRAINING=7

# Performance decline threshold for auto-retraining (percentage)
PERFORMANCE_DECLINE_THRESHOLD=10

# Model storage directory
MODEL_STORAGE_DIR=./models

# Training data directory
TRAINING_DATA_DIR=./training_data

# Enable A/B testing
ENABLE_AB_TESTING=true

# Gradual rollout enabled
ENABLE_GRADUAL_ROLLOUT=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=300

# Alert notification webhook (optional)
ALERT_WEBHOOK_URL=

# Slack webhook for alerts (optional)
SLACK_WEBHOOK_URL=